{
  "name": "read-it-for-me",
  "version": "1.0.0",
  "private": true,
  "description": "Daily digest for links and docs — Express + Svelte + Render Workflows + Together AI",
  "homepage": "https://read-it-for-me.onrender.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ojusave/read-it-for-me"
  },
  "bugs": {
    "url": "https://github.com/ojusave/read-it-for-me/issues"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "workflow:start": "node dist/workflow/index.js",
    "dev": "concurrently -k -n server,vite -c blue,green \"tsx watch server/index.ts\" \"vite\"",
    "dev:workflow": "tsx watch workflow/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@renderinc/sdk": "^0.5.0",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.13.1",
    "render-dds": "git+https://github.com/R4ph-t/DDS.git#c00531cc3d95bcd7ce4c656dd692022779b30c37",
    "together-ai": "^0.16.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "concurrently": "^9.2.0",
    "svelte": "^5.19.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
